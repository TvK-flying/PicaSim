{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "vcpkg-base",
      "hidden": true,
      "inherits": "base",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "VCPKG_MANIFEST_MODE": "ON"
      }
    },
    {
      "name": "windows-x64",
      "displayName": "Windows x64",
      "description": "Windows x64 build with vcpkg (multi-config)",
      "inherits": "vcpkg-base",
      "generator": "Visual Studio 17 2022",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "linux-x64",
      "displayName": "Linux x64",
      "description": "Linux x64 build without vcpkg (no GLAD/OpenXR needed)",
      "inherits": "base",
      "generator": "Ninja Multi-Config",
      "cacheVariables": {
        "PICASIM_ENABLE_VR": "OFF",
        "SDL_PIPEWIRE": "OFF",
        "VCPKG_MANIFEST_MODE": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-arm64",
      "displayName": "Linux ARM64",
      "description": "Linux ARM64 (aarch64) build without vcpkg (no GLAD/OpenXR needed)",
      "inherits": "base",
      "generator": "Ninja Multi-Config",
      "cacheVariables": {
        "PICASIM_ENABLE_VR": "OFF",
        "SDL_PIPEWIRE": "OFF",
        "VCPKG_MANIFEST_MODE": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "macos-x64",
      "displayName": "macOS x64",
      "description": "macOS x64 build with vcpkg",
      "inherits": "vcpkg-base",
      "generator": "Ninja Multi-Config",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-osx",
        "CMAKE_IGNORE_PREFIX_PATH": "/usr/local;/usr/X11R6"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "macos-arm64",
      "displayName": "macOS ARM64",
      "description": "macOS ARM64 (Apple Silicon) build with vcpkg",
      "inherits": "vcpkg-base",
      "generator": "Ninja Multi-Config",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-osx",
        "CMAKE_IGNORE_PREFIX_PATH": "/opt/homebrew;/usr/X11R6"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "ios-device",
      "displayName": "iOS Device",
      "description": "iOS build for physical devices (arm64)",
      "inherits": "base",
      "generator": "Xcode",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "12.0",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "PICASIM_ENABLE_VR": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "ios-simulator",
      "displayName": "iOS Simulator",
      "description": "iOS build for simulator (arm64/x86_64)",
      "inherits": "base",
      "generator": "Xcode",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "12.0",
        "CMAKE_OSX_ARCHITECTURES": "arm64;x86_64",
        "CMAKE_OSX_SYSROOT": "iphonesimulator",
        "PICASIM_ENABLE_VR": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-x64-debug",
      "displayName": "Windows x64 Debug",
      "configurePreset": "windows-x64",
      "configuration": "Debug"
    },
    {
      "name": "windows-x64-release",
      "displayName": "Windows x64 Release",
      "configurePreset": "windows-x64",
      "configuration": "Release"
    },
    {
      "name": "linux-x64-debug",
      "displayName": "Linux x64 Debug",
      "configurePreset": "linux-x64",
      "configuration": "Debug"
    },
    {
      "name": "linux-x64-release",
      "displayName": "Linux x64 Release",
      "configurePreset": "linux-x64",
      "configuration": "Release"
    },
    {
      "name": "linux-arm64-debug",
      "displayName": "Linux ARM64 Debug",
      "configurePreset": "linux-arm64",
      "configuration": "Debug"
    },
    {
      "name": "linux-arm64-release",
      "displayName": "Linux ARM64 Release",
      "configurePreset": "linux-arm64",
      "configuration": "Release"
    },
    {
      "name": "macos-x64-debug",
      "displayName": "macOS x64 Debug",
      "configurePreset": "macos-x64",
      "configuration": "Debug"
    },
    {
      "name": "macos-x64-release",
      "displayName": "macOS x64 Release",
      "configurePreset": "macos-x64",
      "configuration": "Release"
    },
    {
      "name": "macos-arm64-debug",
      "displayName": "macOS ARM64 Debug",
      "configurePreset": "macos-arm64",
      "configuration": "Debug"
    },
    {
      "name": "macos-arm64-release",
      "displayName": "macOS ARM64 Release",
      "configurePreset": "macos-arm64",
      "configuration": "Release"
    },
    {
      "name": "ios-device-debug",
      "displayName": "iOS Device Debug",
      "configurePreset": "ios-device",
      "configuration": "Debug"
    },
    {
      "name": "ios-device-release",
      "displayName": "iOS Device Release",
      "configurePreset": "ios-device",
      "configuration": "Release"
    },
    {
      "name": "ios-simulator-debug",
      "displayName": "iOS Simulator Debug",
      "configurePreset": "ios-simulator",
      "configuration": "Debug"
    },
    {
      "name": "ios-simulator-release",
      "displayName": "iOS Simulator Release",
      "configurePreset": "ios-simulator",
      "configuration": "Release"
    }
  ]
}
